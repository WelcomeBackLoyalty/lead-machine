{
  "name": "lead-machine",
  "version": "1.0.0",
  "description": "General-purpose lead generation tool powered by Exa",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:client && tsc -p tsconfig.json",
    "build:client": "cd client && npm run build",
    "start": "node dist/server.js",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "exa",
    "leads"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "exa-js": "^2.3.0",
    "express": "^5.2.1",
    "json2csv": "^6.0.0-alpha.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/json2csv": "^5.0.7",
    "@types/node": "^25.2.3",
    "concurrently": "^9.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
